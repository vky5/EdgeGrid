# GitHub OAuth app credentials (create at github.com/settings/apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random secret for NextAuth JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Server-side coordinator address (never exposed to browser). The browser only
# ever talks to same-origin /api routes, which forward here with the token below.
COORDINATOR_URL=http://localhost:8080

# Shared backend token: printed by the coordinator on first boot (data/admin.token).
# The coordinator requires this on every request; keep it server-side only.
COORDINATOR_ADMIN_TOKEN=

# Your GitHub username — only this account can approve/reject join requests
# Also set as NEXT_PUBLIC so client components can show/hide admin UI
ADMIN_GITHUB_USERNAME=vky5
NEXT_PUBLIC_ADMIN_GITHUB_USERNAME=vky5
